{
  "$schema": "https://veyra.dev/design-tokens.json",
  "name": "Veyra — Carbon + Signal Amber",
  "scheme": "dark-first",
  "reference": {
    "carbon": "#0D1119",
    "slate": "#151A23",
    "graphite": "#232B36",
    "fog": "#E6EAF0",
    "mist": "#9BA6B5",
    "amber": "#F26A21",
    "amberBright": "#FF8338",
    "teal": "#34D1C4",
    "danger": "#F2555A"
  },
  "semantic": {
    "bg": "carbon",
    "surface": "slate",
    "border": "graphite",
    "text": "fog",
    "textMuted": "mist",
    "accent": "amber",
    "accentHover": "amberBright",
    "info": "teal",
    "danger": "danger"
  },
  "oklch": {
    "carbon": "oklch(16% .015 255)",
    "slate": "oklch(22% .015 250)",
    "graphite": "oklch(30% .020 250)",
    "fog": "oklch(93% .008 250)",
    "mist": "oklch(72% .020 250)",
    "amber": "oklch(68% .18 45)",
    "amberBright": "oklch(74% .17 48)",
    "teal": "oklch(78% .12 185)"
  },
  "typography": {
    "display": { "family": "Sora", "weights": [600, 700] },
    "body": { "family": "IBM Plex Sans", "weights": [400, 500, 600] },
    "mono": { "family": "IBM Plex Mono", "weights": [400, 500] }
  },
  "radii": { "sm": 10, "md": 12, "lg": 14, "xl": 18, "pill": 999 }
}
