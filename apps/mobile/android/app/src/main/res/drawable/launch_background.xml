<?xml version="1.0" encoding="utf-8"?>
<!-- Veyra launch splash: brand-dark background + centered V monogram, so the
     pre-Flutter frame matches the dark app instead of flashing white. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:drawable="@color/veyra_bg" />
    <item
        android:drawable="@drawable/veyra_logo"
        android:gravity="center"
        android:width="96dp"
        android:height="96dp" />
</layer-list>
