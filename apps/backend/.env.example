DATABASE_URL=postgres://veyra:veyra@localhost:5432/veyra
REDIS_URL=redis://localhost:6379
JWT_SECRET=change-me-in-production-use-at-least-32-chars
PORT=8080
RUST_LOG=veyra=debug,tower_http=debug
ACCESS_TTL_SECS=900
REFRESH_TTL_SECS=604800
REFRESH_GRACE_SECS=10
# Local dev over http://localhost: Secure must be false (browsers drop Secure cookies on http).
# SameSite=strict is fine locally: a frontend on localhost:3000 and this API on localhost:8080
# are the SAME site (SameSite ignores the port), so cookies are still sent.
COOKIE_SECURE=false
COOKIE_SAMESITE=strict
# Leave COOKIE_DOMAIN unset locally (only set it in the prod subdomain split, e.g. veyra.dev).
# COOKIE_DOMAIN=veyra.dev
# CORS: needed once a browser frontend on a different ORIGIN calls this API.
# Local frontend dev (Vite/Next on :3000) calling this API on :8080 is cross-origin → set:
# CORS_ALLOWED_ORIGINS=http://localhost:3000
# Production (frontend on its own domain):
# CORS_ALLOWED_ORIGINS=https://veyra.dev,https://app.veyra.dev
